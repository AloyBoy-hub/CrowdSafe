# Backend reads from the repo root .env (see parent directory).
# Add these to the root .env for CCTV:
#   ROBOFLOW_API_KEY=your_private_key
#   ROBOFLOW_MODEL=workspace/project/version   (for legacy /api/cctv/detect)
#   ROBOFLOW_WORKSPACE=your_workspace         (for /api/cctv/workflow)
#   ROBOFLOW_WORKFLOW_ID=your_workflow_id    (e.g. detect-count-and-visualize)

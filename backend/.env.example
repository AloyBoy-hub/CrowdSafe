# Backend reads from the repo root .env (see parent directory).
# Add these to the root .env for CCTV demo:
#   ROBOFLOW_API_KEY=your_private_key
#   ROBOFLOW_MODEL=workspace/project/version   (for legacy /api/cctv/detect)
#   ROBOFLOW_WORKSPACE=abhijith-cbdhq         (for /api/cctv/workflow, optional)
#   ROBOFLOW_WORKFLOW_ID=detect-count-and-visualize   (optional)
